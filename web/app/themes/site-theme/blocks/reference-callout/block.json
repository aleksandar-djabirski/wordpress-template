{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "agency/reference-callout",
  "title": "Reference Callout",
  "category": "text",
  "icon": "megaphone",
  "description": "A heading, body copy, and an optional testimonial pulled live from Site Core — the theme's reference block for building new dynamic blocks.",
  "textdomain": "site-theme",
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "content": {
      "type": "string",
      "default": ""
    },
    "showTestimonial": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "padding": true
    },
    "align": [ "wide" ]
  },
  "render": "file:./render.php",
  "editorScript": "file:./build/index.js",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css"
}
