#!/usr/bin/env bash
#
# Full local verification: the Composer verify suite (validate, audit, phpcs,
# phpstan, deptrac, architecture + unit + integration tests) followed by the
# front-end lint and a production block build. Mirrors what CI runs.
#
# Run inside the DDEV web container, or on a host with php/composer/node on
# PATH. Composer steps fall back to `ddev composer` when only ddev is present.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "${REPO_ROOT}"

if command -v composer >/dev/null 2>&1; then
  COMPOSER=(composer)
elif command -v ddev >/dev/null 2>&1; then
  COMPOSER=(ddev composer)
else
  echo "error: need 'composer' or 'ddev' on PATH." >&2
  exit 1
fi

echo "==> [1/3] Composer verify (lint, static analysis, deptrac, tests)"
"${COMPOSER[@]}" verify

echo "==> [2/3] Front-end lint (eslint + stylelint)"
npm run lint

echo "==> [3/3] Production block build (wp-scripts)"
npm run build

echo "==> All verification steps passed."
