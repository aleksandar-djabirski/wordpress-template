{
    "name": "agency/agency-starter",
    "type": "project",
    "license": "MIT",
    "description": "AI-first WordPress agency starter built on Bedrock.",
    "homepage": "https://github.com/agency/agency-starter",
    "keywords": [
        "bedrock",
        "composer",
        "roots",
        "wordpress"
    ],
    "require": {
        "php": ">=8.2",
        "composer/installers": "^2.0",
        "oscarotero/env": "^2.0",
        "roots/bedrock-autoloader": "^1.0",
        "roots/bedrock-disallow-indexing": "^2.0",
        "roots/wordpress": "^7.0",
        "roots/wp-config": "^1.0",
        "vlucas/phpdotenv": "^5.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "php-stubs/woocommerce-stubs": "^9.0 || ^10.0",
        "php-stubs/wordpress-stubs": "^6.8",
        "php-stubs/wp-cli-stubs": "^2.12",
        "phpcsstandards/phpcsextra": "^1.0",
        "phpcsstandards/phpcsutils": "^1.0",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^9.6",
        "qossmic/deptrac-shim": "^1.0",
        "squizlabs/php_codesniffer": "^3.9",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.0",
        "wp-phpunit/wp-phpunit": "^7.0",
        "yoast/phpunit-polyfills": "^4.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "process-timeout": 0,
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "composer/installers": true,
            "roots/wordpress-core-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "policy": {
            "abandoned": {
                "audit": "report"
            }
        }
    },
    "extra": {
        "installer-paths": {
            "web/app/mu-plugins/{$name}/": [
                "type:wordpress-muplugin"
            ],
            "web/app/plugins/{$name}/": [
                "type:wordpress-plugin"
            ],
            "web/app/themes/{$name}/": [
                "type:wordpress-theme"
            ]
        },
        "wordpress-install-dir": "web/wp"
    },
    "autoload": {
        "psr-4": {
            "AgencyPlatform\\": "web/app/mu-plugins/agency-platform/src/",
            "SiteCore\\": "web/app/plugins/site-core/src/",
            "SiteIntegrations\\": "web/app/plugins/site-integrations/src/",
            "SiteCommerce\\": "web/app/plugins/site-commerce/src/",
            "SiteTheme\\": "web/app/themes/site-theme/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "setup": "echo \"Bootstrap the environment from inside DDEV: 'ddev ssh' then 'bash scripts/setup' (or 'ddev exec bash scripts/setup'). The full setup sequence needs the container's php/wp/node, so it lives in scripts/setup rather than here.\"",
        "lint:php": "phpcs",
        "analyse": "phpstan analyse --memory-limit=1G",
        "deptrac": "deptrac analyse --config-file=deptrac.yaml --no-progress",
        "audit": "composer audit --abandoned=report",
        "test:architecture": "phpunit --testsuite architecture",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": [
            "@putenv WP_INTEGRATION=1",
            "phpunit --testsuite integration"
        ],
        "verify:fast": [
            "composer validate --strict",
            "@audit",
            "@lint:php",
            "@analyse",
            "@deptrac",
            "@test:architecture",
            "@test:unit"
        ],
        "verify": [
            "@verify:fast",
            "@test:integration"
        ]
    }
}
