# Keep operational scripts and the generated block index LF on every platform.
# The scripts carry #!/usr/bin/env shebangs that must run in the DDEV/CI Linux
# containers (a CRLF would break the interpreter line), and the architecture
# suite compares the generated index byte-for-byte, so its line endings must
# be identical everywhere.
scripts/* text eol=lf
docs/generated-block-index.md text eol=lf

# The committed wp-scripts block build output is byte-compared against a fresh
# `npm run build` by ci.yml's frontend build-drift check. Pin its line endings
# to LF so a CRLF checkout on Windows can never make that comparison spuriously
# fail (the build always emits LF).
web/app/themes/site-theme/blocks/**/build/** text eol=lf
