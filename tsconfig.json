{
	"compilerOptions": {
		"target": "es2022",
		"lib": [ "es2022", "dom" ],
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"types": [ "node" ],
		"noEmit": true
	},
	"include": [ "tests/**/*.ts", "playwright.config.ts" ]
}
