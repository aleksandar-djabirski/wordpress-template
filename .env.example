# DDEV default database credentials — matches .ddev/config.yaml.
DB_NAME=db
DB_USER=db
DB_PASSWORD=db
DB_HOST=db

WP_ENV=development
WP_HOME=https://agency-starter.ddev.site
WP_SITEURL=${WP_HOME}/wp

# Auth unique keys and salts.
# These placeholder values are NOT secure — scripts/setup (Task 8) generates
# real random salts for local/CI use. Never deploy with `generateme` salts.
AUTH_KEY=generateme
SECURE_AUTH_KEY=generateme
LOGGED_IN_KEY=generateme
NONCE_KEY=generateme
AUTH_SALT=generateme
SECURE_AUTH_SALT=generateme
LOGGED_IN_SALT=generateme
NONCE_SALT=generateme

# Dev/staging safety default: keeps SiteIntegrations\LeadDelivery\WebhookLeadDelivery
# from firing in non-production environments. See config/environments/{development,staging}.php.
AGENCY_DISABLE_OUTBOUND_WEBHOOKS=true

# Real webhook endpoint for lead delivery; left empty by default (dev/staging
# use SiteIntegrations\LeadDelivery\FakeLeadDelivery instead).
LEAD_WEBHOOK_URL=''
